{
  "name": "mbm-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-event-manifest.mjs",
    "start": "ng serve",
    "prebuild": "node scripts/generate-event-manifest.mjs",
    "build": "ng build",
    "prebuild:local": "node scripts/generate-event-manifest.mjs",
    "build:local": "ng build --configuration development",
    "prebuild:uat": "node scripts/generate-event-manifest.mjs",
    "build:uat": "ng build --configuration uat",
    "prebuild:prod": "node scripts/generate-event-manifest.mjs",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:MBM-App": "node dist/MBM-App/server/server.mjs"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.10",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.8",
    "@ckeditor/ckeditor5-angular": "^11.2.0",
    "ckeditor5": "^48.3.1",
    "exceljs": "^4.4.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
